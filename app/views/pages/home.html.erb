<% content_for :title, "Demo 01 — Home" %>

<main class="home">
  <section class="hero">
    <span class="hero__badge">Demo 01</span>
    <h1 class="hero__title">Build something great.</h1>
    <p class="hero__subtitle">
      A fresh Rails 8 application, ready for whatever you have in mind.
    </p>
    <div class="hero__actions">
      <a class="btn btn--primary" href="https://guides.rubyonrails.org/">Get started</a>
      <a class="btn btn--ghost" href="/up">Health check</a>
    </div>
  </section>

  <section class="features">
    <div class="feature">
      <h3>Hotwire</h3>
      <p>SPA-like speed with Turbo and Stimulus, no extra build step.</p>
    </div>
    <div class="feature">
      <h3>SQLite + Solid</h3>
      <p>Database-backed cache, queue, and cable out of the box.</p>
    </div>
    <div class="feature">
      <h3>Deploy anywhere</h3>
      <p>Ship as a Docker container with Kamal in a single command.</p>
    </div>
  </section>
</main>
